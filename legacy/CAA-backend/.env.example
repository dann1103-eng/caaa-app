# Configuración local del backend CAAA
# Renombrar a .env y completar valores reales.

PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=CAAA
DB_SSL=false

# JWT
JWT_SECRET=cambiame_en_produccion_2026
JWT_EXPIRES_IN=8h

# CORS - frontend en localhost:3000 y :5173 (vite default)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175

# Email (deshabilitado en dev)
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@caaa-sv.com

# Módulo Administración: umbral de bloqueo de saldo (factor)
# 1.0 = bloquear si saldo < costo estimado. 1.5 = exigir 50% extra.
SALDO_FACTOR_BLOQUEO=1.0
