# Configuración local del backend CAAA
# Renombrar a .env y completar valores reales.

PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=CAAA
DB_SSL=false

# JWT
JWT_SECRET=cambiame_en_produccion_2026
# 30 días: la sesión única (usuario.current_session_id, ver authMiddleware) ya
# corta la sesión vieja si alguien entra desde otro dispositivo, así que un
# token de vida larga no debilita esa protección — solo evita que la app pida
# login de nuevo por simple vencimiento cada vez que se reabre tras unas horas
# (el refresh automático del frontend NO puede renovar un token YA vencido:
# jwt.verify lo rechaza igual que a cualquier token inválido).
JWT_EXPIRES_IN=30d

# Llave para pantallas de proyección (TV) sin login.
# Debe coincidir con la usada por el frontend (caaa_proyeccion_secret_2024).
PROYECCION_KEY=caaa_proyeccion_secret_2024

# CORS - frontend en localhost:3000 y :5173 (vite default)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175

# Email / SMTP
#   MAIL_ENABLED=true activa el envío real (si además hay HOST/USER/PASSWORD).
#   Puerto 465 = TLS implícito; 587 = STARTTLS.
#   Gmail: HOST=smtp.gmail.com PORT=465, USER=tucuenta@gmail.com,
#          PASSWORD = "App Password" de 16 dígitos (NO la contraseña normal;
#          requiere verificación en 2 pasos activada en la cuenta Google).
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@caaa-sv.com
MAIL_FROM_NAME=CAAA — Centro de Adiestramiento Aéreo Académico
# URL pública del frontend (para los enlaces dentro de los correos)
APP_PUBLIC_URL=https://caaa-app.vercel.app
# Destinatario(s) de avisos a Administración (examen final aprobado, etc.).
# Coma-separado. Si se deja vacío, usa los correos de los usuarios ADMINISTRACION/ADMIN.
MAIL_ADMIN_NOTIFY=

# Módulo Administración: umbral de bloqueo de saldo (factor)
# 1.0 = bloquear si saldo < costo estimado. 1.5 = exigir 50% extra.
SALDO_FACTOR_BLOQUEO=1.0
